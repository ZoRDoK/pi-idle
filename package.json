{
	"name": "pi-idle",
	"version": "1.0.5",
	"description": "Pi extension: shows ✓ in terminal title when idle, spinner (◰◳◲◱) while working, with context-usage percentage beside the checkmark",
	"keywords": [
		"idle",
		"done",
		"spinner",
		"pi-extension",
		"pi-package"
	],
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ZoRDoK/pi-idle.git"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"pi": {
		"extensions": [
			"./pi-idle.ts"
		]
	},
	"devDependencies": {
		"vitest": "^3.2.4"
	}
}
